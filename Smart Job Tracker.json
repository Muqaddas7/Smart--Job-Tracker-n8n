              "name": "Authorization",
              "value": "Bearer YOUR_GROQ_API_KEY_HERE"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"model\": \"meta-llama/llama-4-scout-17b-16e-instruct\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a job matching assistant for a final-year AI Engineering student (graduating 2027) with skills in Python, FastAPI, LangChain, RAG, Groq, React, and n8n automation, targeting AI Engineer, ML Engineer, NLP Engineer, or Backend Developer roles. From the list of jobs provided, return only jobs that fit this profile at Entry to Mid level (exclude Senior/Staff/Principal/Director/5+ years experience roles), that are REMOTE or based in Germany, Netherlands, Sweden, Norway, Denmark, Finland, France, Spain, Portugal, UK, Ireland, Poland, Czech Republic, or Austria. Only include jobs posted within the last 24 hours based on the date field. For each match, return title, company, location, date, url, and a match_score (0-100) with a one-line reason. Return ONLY a raw JSON array with no markdown formatting, no code blocks. Empty array if no matches.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": JSON.stringify($input.all().flatMap(item => (item.json.jobs || []).map(j => ({t: j.title, l: j.location?.name, c: j.company_name, d: j.first_published, u: j.absolute_url}))).slice(0, 100))\n    }\n  ]\n} }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [560, 96],
      "id": "c942d627-36be-43e0-8ff3-00b54370a9cf",
      "name": "HTTP Request3"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\n// Existing sheet se URLs nikal lo (duplicate check ke liye)\nlet existingUrls = [];\ntry {\n  const existingRows = $('Get existing jobs').all();\n  existingUrls = existingRows.map(row => row.json.url).filter(Boolean);\n} catch (e) {\n  existingUrls = [];\n}\n\nfor (const item of items) {\n  const content = item.json.choices[0].message.content;\n  \n  let cleanContent = content.trim();\n  cleanContent = cleanContent.replace(/```json\\n?/g, '').replace(/```\\n?/g, '');\n  \n  try {\n    const jobs = JSON.parse(cleanContent);\n    for (const job of jobs) {\n      const jobUrl = job.u || job.url;\n      \n      // Sirf naya (non-duplicate) job add karo\n      if (!existingUrls.includes(jobUrl)) {\n        results.push({\n          json: {\n            title: job.t || job.title,\n            company: job.c || job.company,\n            location: job.l || job.location,\n            date: job.d || job.date,\n            url: jobUrl,\n            match_score: job.match_score,\n            reason: job.reason\n          }\n        });\n        existingUrls.push(jobUrl); // isi run ke andar bhi duplicate na ho\n      }\n    }\n  } catch (e) {\n    // Skip if parsing fails\n  }\n}\n\nreturn results;"
      },
