    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet jobsHtml = '';\n\nfor (const item of items) {\n  const job = item.json;\n  jobsHtml += `\n    <div style=\"margin-bottom: 20px; padding: 15px; border: 1px solid #ddd; border-radius: 8px;\">\n      <h3>${job.Title || job.title}</h3>\n      <p>\n        Company: ${job.Company || job.company}<br>\n        Location: ${job.Location || job.location}<br>\n        Match Score: ${job['Match Score'] || job.match_score}/100<br>\n        Reason: ${job.Reason || job.reason}\n      </p>\n      <p><a href=\"${job.url}\">Apply Now</a></p>\n    </div>\n  `;\n}\n\nreturn [\n  {\n    json: {\n      emailHtml: jobsHtml,\n      totalJobs: items.length\n    }\n  }\n];"
      },
